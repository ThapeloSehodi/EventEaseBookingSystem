@model EventEaseBookingSystem.Models.Venue

@{
    ViewData["Title"] = "Edit Venue";
}

<h2>Edit Venue</h2>

<form asp-action="Edit" enctype="multipart/form-data">

    <input type="hidden" asp-for="VenueId" />

    <div class="form-group">
        <label asp-for="VenueName"></label>
        <input asp-for="VenueName" class="form-control" />
        <span asp-validation-for="VenueName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Location"></label>
        <input asp-for="Location" class="form-control" />
        <span asp-validation-for="Location" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Capacity"></label>
        <input asp-for="Capacity" class="form-control" />
        <span asp-validation-for="Capacity" class="text-danger"></span>
    </div>

    <br />

    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <div>
            <p>Current Image:</p>

            <img src="@Model.ImageUrl"
                 width="150"
                 height="100"
                 style="object-fit:cover;" />
        </div>

        <br />
    }

    <div class="form-group">
        <label>Upload New Image</label>

        <input asp-for="ImageFile"
               type="file"
               class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-success">
        Save Changes
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Back
    </a>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}