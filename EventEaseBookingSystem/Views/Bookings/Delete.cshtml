@model EventEaseBookingSystem.Models.Booking

@{
    ViewData["Title"] = "Delete Booking";
}

<h2>Delete Booking</h2>

<div class="alert alert-danger">
    <p>Are you sure you want to delete this booking?</p>
</div>

<div class="card p-3 mb-3">
    <p><strong>Booking ID:</strong> @Model.BookingId</p>
    <p><strong>Customer:</strong> @(Model.Customer?.FullName ?? "N/A")</p>
    <p><strong>Event:</strong> @(Model.Event?.EventName ?? "N/A")</p>
    <p><strong>Booking Date:</strong> @Model.BookingDate.ToShortDateString()</p>
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="BookingId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>